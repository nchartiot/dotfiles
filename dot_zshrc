# Enable Zsh autocompletion system
autoload -Uz compinit && compinit

# Load the completion list module
zmodload zsh/complist

# Generate the LS_COLORS environment variable
eval "$(dircolors -b)"

# Feed LS_COLORS to the completion menu
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}

# Enable arrow-key navigation for the completion menu
zstyle ':completion:*' menu select

# Enable plugins
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Persist and share shell history across terminals.
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_FCNTL_LOCK

eval "$(zoxide init zsh)"
eval "$(starship init zsh)"

# Make Ctrl+Left/Right move by word instead of inserting escape fragments.
for keymap in emacs viins; do
  [[ -n "${terminfo[kLFT5]}" ]] && bindkey -M "$keymap" "${terminfo[kLFT5]}" backward-word
  [[ -n "${terminfo[kRIT5]}" ]] && bindkey -M "$keymap" "${terminfo[kRIT5]}" forward-word
  bindkey -M "$keymap" '^[[1;5D' backward-word
  bindkey -M "$keymap" '^[[1;5C' forward-word
  bindkey -M "$keymap" '^[[5D' backward-word
  bindkey -M "$keymap" '^[[5C' forward-word
done

